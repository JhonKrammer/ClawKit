# ClawKit .gitignore文件
# 过滤非代码文件

# 编译生成的文件
dist/
build/
*.spec

# 临时文件
__pycache__/
*.py[cod]
*$py.class

# 日志文件
*.log

# 环境文件
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE相关文件
.idea/
.vscode/
*.swp
*.swo
*~

# 操作系统相关文件
Thumbs.db
.DS_Store

# Python相关文件
*.egg-info/
.pytest_cache/
.tox/
.venv/

# 其他临时文件
*.tmp
*.temp
.cache/
